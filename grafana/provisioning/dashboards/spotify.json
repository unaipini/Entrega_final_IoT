            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "\n(SELECT track_genre AS \"Género\", avg_energy AS \"Energía\"\n FROM gold_genre_stats WHERE track_count >= 50\n ORDER BY avg_energy DESC LIMIT 9)\nUNION ALL\n(SELECT track_genre AS \"Género\", avg_energy AS \"Energía\"\n FROM gold_genre_stats WHERE track_count >= 50\n ORDER BY avg_energy ASC LIMIT 9)\nORDER BY \"Energía\" DESC;",
          "refId": "A"
        }
      ],
