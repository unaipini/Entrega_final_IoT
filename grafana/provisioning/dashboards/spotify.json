    {
      "id": 7,
      "type": "timeseries",
      "title": "Evolución sonora por década — ¿cómo ha cambiado la música?",
      "description": "La música se ha vuelto más bailable y energética con los años. Party Index sube consistentemente desde los 60. El pico de acústica en los 70 coincide con el folk-rock. Desde 2010 la positividad cae mientras sube la energía.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n    make_timestamp(release_year::int, 6, 15, 0, 0, 0) AS \"time\",\n    avg_danceability  AS \"Bailabilidad\",\n    avg_energy        AS \"Energía\",\n    avg_valence       AS \"Positividad\",\n    avg_acousticness  AS \"Acústica\",\n    avg_party_index   AS \"Party Index 🎉\"\nFROM gold_temporal_trends\nWHERE release_year BETWEEN 1960 AND 2026\nORDER BY release_year;",
          "refId": "A",
          "timeColumn": "time"
        }
      ],
      "options": {
