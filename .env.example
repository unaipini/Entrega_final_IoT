# ============================================================
# Copia este fichero a .env y rellena los valores reales:
#   cp .env.example .env
# ¡Nunca subas .env al repositorio! Ya está en .gitignore.
# ============================================================

# --- Spotify API ---
# Crea una app en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui

# --- PostgreSQL ---
POSTGRES_USER=spotify
POSTGRES_PASSWORD=spotify_pass
POSTGRES_DB=spotify_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MQTT (Mosquitto) ---
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=spotify/tracks

# --- Producer ---
# Segundos entre mensajes al publicar el CSV (0.05 = ~20 msg/s)
CSV_PUBLISH_INTERVAL=0.05

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://spotify:spotify_pass@postgres/spotify_db
AIRFLOW__CORE__FERNET_KEY=tu_fernet_key_aqui
AIRFLOW__WEBSERVER__SECRET_KEY=tu_secret_key_aqui
