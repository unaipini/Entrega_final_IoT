    {
      "id": 10,
      "type": "barchart",
      "title": "¿Qué géneros tienen más contenido explícito? (Top 15)",
      "description": "Sorpresa: comedy lidera con ~66% de canciones explícitas, seguido de emo y sad, ambos por encima de hip-hop. El contenido adulto no se concentra donde la gente asume.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 12,
        "h": 11
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    track_genre AS \"Género\",\n    ROUND(100.0 * SUM(CASE WHEN explicit THEN 1 ELSE 0 END) / COUNT(*), 1) AS \"% Explícito\"\nFROM tracks\nWHERE track_genre IS NOT NULL AND track_genre NOT IN ('Unknown','')\nGROUP BY track_genre\nHAVING COUNT(*) >= 50\nORDER BY \"% Explícito\" DESC\nLIMIT 15;",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "fillOpacity": 80,
