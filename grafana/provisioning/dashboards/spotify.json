    {
      "id": 9,
      "type": "barchart",
      "title": "Los géneros con más y menos energía (Top 9 + Bottom 9)",
      "description": "Death-metal y grindcore superan el 0.92 de energía; classical y new-age no llegan al 0.22. La diferencia entre extremos es más de 4×, confirmando que el género captura algo real sobre intensidad sonora.",
      "datasource": {
