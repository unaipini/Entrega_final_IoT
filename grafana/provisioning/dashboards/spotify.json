          "rawQuery": true,
          "rawSql": "SELECT\n    ROW_NUMBER() OVER (ORDER BY af.party_index DESC) AS \"#\",\n    t.name          AS \"Canción\",\n    ar.name         AS \"Artista\",\n    t.track_genre   AS \"Género\",\n    t.popularity    AS \"Popularidad\",\n    af.party_index  AS \"Party Index 🎉\",\n    af.danceability AS \"Baile\",\n    af.energy       AS \"Energía\",\n    af.valence      AS \"Positividad\",\n    t.source        AS \"Fuente\"\nFROM tracks t\nJOIN audio_features af ON t.id = af.track_id\nLEFT JOIN artists ar   ON t.artist_id = ar.id\nWHERE af.party_index IS NOT NULL\nORDER BY af.party_index DESC\nLIMIT 15;",
