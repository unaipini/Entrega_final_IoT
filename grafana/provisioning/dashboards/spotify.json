    {
      "id": 8,
      "type": "table",
      "title": "¿Ha cambiado el sonido? Histórico (CSV) vs. Nuevos lanzamientos (API)",
      "description": "Comparativa directa entre las canciones históricas del dataset de Kaggle y los nuevos lanzamientos capturados en tiempo real por la API de Spotify. Responde si la música actual suena diferente a la que fue popular en el pasado.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 11,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n    CASE t.source\n        WHEN 'csv' THEN '📀 Histórico (CSV Kaggle)'\n        ELSE            '🆕 Nuevos lanzamientos (API)'\n    END                                             AS \"Fuente\",\n    COUNT(*)                                        AS \"Tracks\",\n    ROUND(AVG(t.popularity)::numeric, 1)            AS \"Popularidad\",\n    ROUND(AVG(af.danceability)::numeric, 3)         AS \"Bailabilidad\",\n    ROUND(AVG(af.energy)::numeric, 3)               AS \"Energía\",\n    ROUND(AVG(af.valence)::numeric, 3)              AS \"Positividad\",\n    ROUND(AVG(af.acousticness)::numeric, 3)         AS \"Acústica\",\n    ROUND(AVG(af.party_index)::numeric, 3)          AS \"Party Index\"\nFROM tracks t\nJOIN audio_features af ON af.track_id = t.id\nGROUP BY t.source\nORDER BY t.source;",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
