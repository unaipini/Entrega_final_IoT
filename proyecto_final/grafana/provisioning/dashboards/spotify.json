{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Pipeline IoT Spotify — datos ingestados vía MQTT, procesados por Airflow y almacenados en PostgreSQL.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total de pistas ingestadas",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS total FROM tracks;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Índice de Fiesta Medio",
      "description": "Media de (danceability + energy + valence) / 3 sobre todas las pistas.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(party_index)::numeric, 3) AS party_index FROM audio_features;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.4  },
              { "color": "green",  "value": 0.7  }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Pistas por Fuente",
      "description": "Proporción de pistas cuyo origen es el CSV histórico vs. la API de Spotify en tiempo real.",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT source, COUNT(*) AS total FROM tracks GROUP BY source;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "csv" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "api" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pistas ingestadas por minuto",
      "description": "Velocidad de ingesta en tiempo real. Muestra cuántas canciones llegan por minuto desde el broker MQTT.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('minute', ingested_at) AS time, source, COUNT(*) AS pistas FROM tracks WHERE $__timeFilter(ingested_at) GROUP BY 1, 2 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Top 10 Canciones por Índice de Fiesta",
      "description": "Las 10 canciones con mayor party_index. Este campo lo calcula el ETL de Airflow, no viene de Spotify.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT track_name || ' — ' || artist_name AS cancion, party_index FROM vw_tracks_with_party WHERE party_index IS NOT NULL ORDER BY party_index DESC LIMIT 10;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "unit": "percentunit",
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Distribución de Energía vs Bailabilidad",
      "description": "Comparación de energy y danceability medios por fuente de datos.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT t.source, ROUND(AVG(af.energy)::numeric, 3) AS energia_media, ROUND(AVG(af.danceability)::numeric, 3) AS bailabilidad_media FROM audio_features af JOIN tracks t ON af.track_id = t.id GROUP BY t.source;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "unit": "percentunit"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["spotify", "iot", "mqtt", "airflow"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Spotify IoT Pipeline",
  "uid": "spotify-iot-pipeline",
  "version": 1
}
