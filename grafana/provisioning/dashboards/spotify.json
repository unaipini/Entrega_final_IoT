    {
      "id": 6,
      "type": "barchart",
      "title": "¿Qué géneros tienen más contenido explícito? (Top 15)",
      "description": "Resultado sorprendente: comedy lidera con el 66% de canciones explícitas, seguido de emo (46%) y sad (45%), ambos por encima de hip-hop (32%). El contenido adulto no se concentra donde la gente asume. Dato relevante para sistemas de recomendación y control parental.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n    track_genre AS \"Género\",\n    ROUND(100.0 * SUM(CASE WHEN explicit THEN 1 ELSE 0 END) / COUNT(*), 1) AS \"% Explícito\",\n    COUNT(*) AS \"Total tracks\"\nFROM tracks\nWHERE track_genre IS NOT NULL\n  AND track_genre NOT IN ('Unknown', '')\nGROUP BY track_genre\nHAVING COUNT(*) >= 50\nORDER BY \"% Explícito\" DESC\nLIMIT 15;",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xField": "Género",
        "barWidth": 0.7,
        "fillOpacity": 75,
        "gradientMode": "none",
        "tooltip": {
