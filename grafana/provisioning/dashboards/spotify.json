          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    gs.track_genre                              AS \"Género\",\n    gs.track_count                              AS \"Tracks\",\n    ROUND(AVG(af.speechiness)::numeric, 3)      AS \"Habla (Speechiness)\",\n    ROUND(AVG(af.instrumentalness)::numeric, 3) AS \"Instrumental\"\nFROM gold_genre_stats gs\nJOIN tracks t       ON t.track_genre = gs.track_genre\nJOIN audio_features af ON af.track_id = t.id\nWHERE gs.track_count >= 50\nGROUP BY gs.track_genre, gs.track_count\nORDER BY \"Habla (Speechiness)\" DESC\nLIMIT 20;",
          "refId": "A"
        }
