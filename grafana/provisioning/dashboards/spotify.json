    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingesta en tiempo real — Mensajes Bronze por minuto",
      "description": "Demuestra que el pipeline está vivo: cada barra es un minuto de actividad. El pico inicial corresponde al volcado del CSV histórico.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n    date_trunc('minute', received_at) AS \"time\",\n    COUNT(*) FILTER (WHERE payload->>'data_source' = 'csv')  AS \"CSV (histórico)\",\n    COUNT(*) FILTER (WHERE payload->>'data_source' = 'api')  AS \"API (tiempo real)\",\n    COUNT(*) AS \"Total\"\nFROM bronze_raw\nWHERE received_at >= NOW() - INTERVAL '3 hours'\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CSV (histórico)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5B9BD5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "API (tiempo real)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#1DB954"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#E07B39"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Fuente de datos: CSV vs API",
      "description": "Compara el histórico de Kaggle con los nuevos lanzamientos capturados en tiempo real. ¿Ha cambiado el sonido de la música?",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    CASE t.source WHEN 'csv' THEN '📀 Histórico CSV' ELSE '🆕 API Spotify' END AS \"Fuente\",\n    COUNT(*)                                    AS \"Tracks\",\n    ROUND(AVG(t.popularity)::numeric,1)         AS \"Popularidad\",\n    ROUND(AVG(af.danceability)::numeric,3)      AS \"Bailabilidad\",\n    ROUND(AVG(af.energy)::numeric,3)            AS \"Energía\",\n    ROUND(AVG(af.valence)::numeric,3)           AS \"Positividad\",\n    ROUND(AVG(af.party_index)::numeric,3)       AS \"Party Index\"\nFROM tracks t\nJOIN audio_features af ON af.track_id = t.id\nGROUP BY t.source ORDER BY t.source;",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Bailabilidad"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
