          "rawSql": "\nSELECT\n    t.name                              AS \"Canción\",\n    t.track_genre                       AS \"Género\",\n    t.popularity                        AS \"Popularidad\",\n    af.party_index                      AS \"Party Index\",\n    af.danceability                     AS \"Bailabilidad\",\n    af.energy                           AS \"Energía\",\n    af.valence                          AS \"Positividad\"\nFROM tracks t\nJOIN audio_features af ON t.id = af.track_id\nWHERE af.party_index IS NOT NULL\nORDER BY af.party_index DESC\nLIMIT 10;",
