    {
      "id": 8,
      "type": "table",
      "title": "¿Es popular lo que baila? Los 20 géneros más escuchados",
      "description": "Hallazgo: los géneros más populares NO son los más bailables. 'sad', 'chill' y 'pop-film' lideran en popularidad con party_index bajo. Reggaeton y dancehall tienen mayor party_index pero menos oyentes.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 14,
        "h": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    track_genre       AS \"Género\",\n    track_count       AS \"Tracks\",\n    avg_popularity    AS \"Popularidad\",\n    avg_party_index   AS \"Party Index\",\n    avg_danceability  AS \"Bailabilidad\",\n    avg_energy        AS \"Energía\",\n    avg_valence       AS \"Positividad\"\nFROM gold_genre_stats\nWHERE track_count >= 100\nORDER BY avg_popularity DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "options": {
