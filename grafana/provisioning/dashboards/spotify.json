    {
      "id": 7,
      "type": "table",
      "title": "Géneros que hablan vs géneros que suenan",
      "description": "La speechiness mide cuánto 'habla' hay en una canción. Comedy (0.76) y dancehall (0.19) lideran. En el extremo opuesto, la instrumentalness alta identifica géneros sin voz: classical, ambient, new-age. Son dos formas opuestas de hacer música, y los datos las separan perfectamente.",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n    track_genre             AS \"Género\",\n    avg_popularity          AS \"Popularidad\",\n    ROUND(gs.avg_speechiness::numeric, 3) AS \"% Habla (Speechiness)\",\n    ROUND(gs.avg_instrumentalness::numeric, 3) AS \"% Instrumental\",\n    track_count             AS \"Tracks\"\nFROM (\n    SELECT\n        gs.track_genre,\n        gs.avg_popularity,\n        gs.track_count,\n        AVG(af.speechiness)     AS avg_speechiness,\n        AVG(af.instrumentalness) AS avg_instrumentalness\n    FROM gold_genre_stats gs\n    JOIN tracks t  ON t.track_genre = gs.track_genre\n    JOIN audio_features af ON af.track_id = t.id\n    WHERE gs.track_count >= 50\n    GROUP BY gs.track_genre, gs.avg_popularity, gs.track_count\n) gs\nORDER BY \"% Habla (Speechiness)\" DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "% Habla (Speechiness)",
            "desc": true
