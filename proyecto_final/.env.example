# .env.example
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas .env al repositorio (está en .gitignore).

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=spotify_user
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=spotify_db

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=cambia_esta_password

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=GENERA_UNA_CLAVE_FERNET_AQUI
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=cambia_esta_password

# ---------------------------------------------------------------------------
# MQTT
# ---------------------------------------------------------------------------
MQTT_TOPIC=spotify/tracks

# ---------------------------------------------------------------------------
# Spotify API  (https://developer.spotify.com/dashboard)
# ---------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=tu_client_id_de_spotify
SPOTIFY_CLIENT_SECRET=tu_client_secret_de_spotify

# ---------------------------------------------------------------------------
# Productor
# ---------------------------------------------------------------------------
# Segundos entre cada publicación de fila del CSV (0.05 = ~20 tracks/seg)
CSV_PUBLISH_INTERVAL=0.05
